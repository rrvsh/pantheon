{
  "module": {
    "prefix": "mod",
    "body": [
      "{ config, lib, ... }:",
      "let",
      "  inherit (lib) mkEnableOption mkIf;",
      "  cfg = config.$1;",
      "in",
      "{",
      "  options.$2 = {",
      "    enable = mkEnableOption \"$3\";",
      "  };",
      "",
      "  config = mkIf cfg.enable {",
      "    $4",
      "  };",
      "}"
    ],
    "description": "empty module"
  }
}
